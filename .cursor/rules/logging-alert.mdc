## 集成到策略中

在策略中集成日志和告警：

```python
class MyStrategy(BaseCtaStrategyV6):
    """示例策略"""
    
    def __init__(self, cta_engine, strategy_name, vt_symbol, setting):
        """初始化"""
        super().__init__(cta_engine, strategy_name, vt_symbol, setting)
        
        # 初始化日志
        self.logger = logger.bind(
            strategy=strategy_name,
            symbol=vt_symbol
        )
        
        # 初始化告警管理器
        self.alert_manager = AlertManager()
        
    def on_init(self):
        """初始化"""
        self.logger.info("策略初始化")
        self.load_bar(10)
        
    def on_start(self):
        """启动"""
        self.logger.info("策略启动")
        self.alert_manager.send_alert(
            f"策略{self.strategy_name}在{self.vt_symbol}上启动",
            level="INFO"
        )
        
    def on_stop(self):
        """停止"""
        self.logger.info("策略停止")
        self.alert_manager.send_alert(
            f"策略{self.strategy_name}在{self.vt_symbol}上停止",
            level="INFO"
        )
        
    def on_bar(self, bar):
        """K线更新"""
        try:
            # 策略逻辑
            signal = self.generate_signal()
            
            if signal > 0:
                self.logger.info(f"生成买入信号，价格={bar.close_price}")
                self.alert_manager.send_alert(
                    f"策略{self.strategy_name}在{self.vt_symbol}上触发买入信号",
                    level="INFO"
                )
                
            elif signal < 0:
                self.logger.info(f"生成卖出信号，价格={bar.close_price}")
                self.alert_manager.send_alert(
                    f"策略{self.strategy_name}在{self.vt_symbol}上触发卖出信号",
                    level="INFO"
                )
                
        except Exception as e:
            self.logger.error(f"策略执行异常: {e}")
            self.alert_manager.send_alert(
                f"策略{self.strategy_name}执行异常: {e}",
                level="ERROR"
            )
```